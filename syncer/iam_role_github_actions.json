{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Action": "sts:AssumeRoleWithWebIdentity",
            "Effect": "Allow",
            "Principal": {
                "Federated": "${github_actions_arn}"
            },
            "Condition": {
                "StringLike": {
                    "token.actions.githubusercontent.com:sub": "repo:${github_user_name}/${github_repository_name}:*"
                },
                "StringEquals": {
                    "token.actions.githubusercontent.com:aud": "sts.amazonaws.com"
                }
            }
        }
    ]
  }